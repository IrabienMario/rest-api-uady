# ── Servidor ──────────────────────────────────────
PORT=3000

# ── Base de datos RDS (MySQL) ──────────────────────
DB_HOST=tu-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=sicei
DB_USER=admin
DB_PASSWORD=tu_password

# ── AWS Credenciales (del botón AWS Details) ───────
AWS_ACCESS_KEY_ID=ASIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=...
AWS_DEFAULT_REGION=us-east-1

# ── S3 ─────────────────────────────────────────────
S3_BUCKET_NAME=sicei-fotos-alumnos

# ── SNS ────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:sicei-notificaciones

# ── DynamoDB ────────────────────────────────────────
DYNAMODB_TABLE=sesiones-alumnos
